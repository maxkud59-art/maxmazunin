generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── System ───────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  USER
}

// ─── Messenger ────────────────────────────────────────────────────────────────

enum MessengerRole {
  GEN_DIRECTOR
  COMMERCIAL_DIRECTOR
  SALES_DIRECTOR
  ROP
  MANAGER
  DESIGN_DIRECTOR
  DESIGNER
  PRODUCTION_HEAD
  ASSEMBLER
  PROGRAMMER
  ACCOUNTANT
  OTHER
}

enum Company {
  IZIBOOK
  IZINEON
}

enum ChatType {
  DIRECT
  GROUP
  NEWS
}

enum ChatMemberRole {
  OWNER
  ADMIN
  MEMBER
}

enum MessageType {
  TEXT
  FILE
  IMAGE
  VIDEO
  SYSTEM
}

enum AttachmentKind {
  FILE
  IMAGE
  VIDEO
  DOC
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  passwordHash String
  role         Role          @default(USER)
  createdAt    DateTime      @default(now())

  // Messenger profile
  firstName     String?
  lastName      String?
  nickname      String?       @unique
  avatarUrl     String?
  jobTitle      String?
  messengerRole MessengerRole @default(OTHER)
  companies     Company[]

  // Relations
  sentMessages      Message[]           @relation("SentMessages")
  memberships       ChatMember[]
  mentions          Mention[]
  gendirGrants      GendirAccessGrant[] @relation("GrantedTo")
  gendirGrantsGiven GendirAccessGrant[] @relation("GrantedBy")
  bookProjects      BookProject[]
  messageReads      MessageRead[]
  createdChats      Chat[]
}

model Chat {
  id          String     @id @default(cuid())
  type        ChatType
  title       String?
  avatarUrl   String?
  company     Company?   // для NEWS-каналов
  createdById String
  createdAt   DateTime   @default(now())

  createdBy   User        @relation(fields: [createdById], references: [id])
  members     ChatMember[]
  messages    Message[]
}

model ChatMember {
  id                String         @id @default(cuid())
  chatId            String
  userId            String
  role              ChatMemberRole @default(MEMBER)
  lastReadMessageId String?
  canLeave          Boolean        @default(true)
  muted             Boolean        @default(false)
  joinedAt          DateTime       @default(now())

  chat Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([chatId, userId])
}

model Message {
  id          String      @id @default(cuid())
  chatId      String
  senderId    String
  type        MessageType @default(TEXT)
  body        String      @default("")
  replyToId   String?
  createdAt   DateTime    @default(now())
  editedAt    DateTime?
  deletedAt   DateTime?

  chat        Chat          @relation(fields: [chatId], references: [id], onDelete: Cascade)
  sender      User          @relation("SentMessages", fields: [senderId], references: [id])
  replyTo     Message?      @relation("Replies", fields: [replyToId], references: [id])
  replies     Message[]     @relation("Replies")
  attachments Attachment[]
  mentions    Mention[]
  reads       MessageRead[]

  @@index([chatId, createdAt])
}

model Attachment {
  id         String         @id @default(cuid())
  messageId  String
  kind       AttachmentKind
  storageKey String
  fileName   String
  mime       String
  sizeBytes  Int

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
}

model Mention {
  id        String @id @default(cuid())
  messageId String
  userId    String

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
}

model GendirAccessGrant {
  id        String   @id @default(cuid())
  userId    String
  grantedBy String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  user      User @relation("GrantedTo", fields: [userId], references: [id], onDelete: Cascade)
  grantor   User @relation("GrantedBy", fields: [grantedBy], references: [id])

  @@unique([userId])
}

model MessageRead {
  messageId String
  userId    String
  readAt    DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([messageId, userId])
}

// ─── VK Ads ───────────────────────────────────────────────────────────────────

model VkCabinet {
  id                String       @id @default(cuid())
  title             String
  externalAccountId String       @unique
  isActive          Boolean      @default(false)
  createdAt         DateTime     @default(now())
  snapshots         AdSnapshot[]
  hourlyStats       HourlyStat[]
}

model AdSnapshot {
  id            String    @id @default(cuid())
  capturedAt    DateTime
  cabinetId     String
  campaignId    String
  campaignName  String
  impressions   Int       @default(0)
  clicks        Int       @default(0)
  spend         Float     @default(0)
  leads         Int       @default(0)
  isPreliminary Boolean   @default(true)
  cabinet       VkCabinet @relation(fields: [cabinetId], references: [id])

  @@index([cabinetId, campaignId, capturedAt])
}

model HourlyStat {
  id               String    @id @default(cuid())
  hourStartUtc     DateTime
  cabinetId        String
  campaignId       String
  campaignName     String
  impressionsDelta Int       @default(0)
  clicksDelta      Int       @default(0)
  spendDelta       Float     @default(0)
  leadsDelta       Int       @default(0)
  cpm              Float?
  cpc              Float?
  cpl              Float?
  isPreliminary    Boolean   @default(false)
  cabinet          VkCabinet @relation(fields: [cabinetId], references: [id])

  @@unique([cabinetId, campaignId, hourStartUtc])
}

// ─── Book Layout ──────────────────────────────────────────────────────────────

enum BookSize {
  S20x20
  S20x30
  S25x25
  S30x30
}

enum SpreadKind {
  COVER
  SPREAD
}

model BookProject {
  id          String    @id @default(cuid())
  orderNumber String?   @unique
  title       String
  size        BookSize  @default(S20x20)
  shareToken  String    @unique @default(cuid())
  createdById String
  createdBy   User      @relation(fields: [createdById], references: [id])
  photos      BookPhoto[]
  spreads     BookSpread[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model BookPhoto {
  id               String       @id @default(cuid())
  bookProjectId    String
  bookProject      BookProject  @relation(fields: [bookProjectId], references: [id], onDelete: Cascade)
  storageKey       String
  thumbKey         String
  fileName         String
  width            Int          @default(0)
  height           Int          @default(0)
  takenAt          DateTime?
  order            Int          @default(0)
  uploadedAt       DateTime     @default(now())
  enhancedKey      String?
  enhancedThumbKey String?
  useEnhanced      Boolean      @default(false)
  placements       BookPlacement[]
}

model BookSpread {
  id            String          @id @default(cuid())
  bookProjectId String
  bookProject   BookProject     @relation(fields: [bookProjectId], references: [id], onDelete: Cascade)
  index         Int
  kind          SpreadKind      @default(SPREAD)
  templateId    String?
  placements    BookPlacement[]
  textElements  BookTextElement[]
}

model BookPlacement {
  id        String     @id @default(cuid())
  spreadId  String
  spread    BookSpread @relation(fields: [spreadId], references: [id], onDelete: Cascade)
  photoId   String
  photo     BookPhoto  @relation(fields: [photoId], references: [id], onDelete: Cascade)
  cellIndex Int        @default(0)
  rotation  Float      @default(0)
  scale     Float      @default(1)
  panX      Float      @default(50)
  panY      Float      @default(50)
  z         Int        @default(0)
}

model BookTextElement {
  id         String     @id @default(cuid())
  spreadId   String
  spread     BookSpread @relation(fields: [spreadId], references: [id], onDelete: Cascade)
  text       String
  fontFamily String     @default("Inter")
  fontSize   Int        @default(16)
  color      String     @default("#000000")
  x          Float      @default(0)
  y          Float      @default(0)
  w          Float      @default(200)
  h          Float      @default(40)
}

// ─── VK Messenger (ИИ-ассистент) ──────────────────────────────────────────────

enum VkDirection {
  IN
  OUT
}

model VkConversation {
  id              String    @id @default(cuid())
  peerId          Int       @unique
  peerType        String    @default("user")
  clientName      String    @default("")
  clientAvatar    String?
  lastMessageText String    @default("")
  lastMessageAt   DateTime  @default(now())
  unreadCount     Int       @default(0)
  crmStatus       String?
  assignedBotId   String?
  botPaused       Boolean   @default(false)
  updatedAt       DateTime  @updatedAt

  messages  VkMessage[]
  client    VkClient?

  @@index([lastMessageAt])
}

model VkMessage {
  id             String         @id @default(cuid())
  conversationId String
  vkMessageId    Int
  direction      VkDirection
  text           String         @default("")
  attachments    Json           @default("[]")
  senderName     String         @default("")
  createdAt      DateTime

  conversation   VkConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@unique([conversationId, vkMessageId])
  @@index([conversationId, createdAt])
}

model VkClient {
  id              String         @id @default(cuid())
  peerId          Int            @unique
  fio             String?
  firstName       String?
  lastName        String?
  vkUrl           String?
  avatar          String?
  phone           String?
  email           String?
  birthDate       DateTime?
  country         String?
  city            String?
  source          String?
  note            String?
  tags            Json           @default("[]")
  firstContactAt  DateTime?
  nextContactDate DateTime?
  lastContactAt   DateTime?
  crmStatusId     String?

  conversation    VkConversation        @relation(fields: [peerId], references: [peerId])
  crmStatus       CrmStatus?            @relation(fields: [crmStatusId], references: [id])
  tagLinks        ClientTag[]
  orders          Order[]
  scenarioStates  ClientScenarioState[]

  @@index([firstContactAt])
  @@index([nextContactDate])
  @@index([crmStatusId])
  @@index([phone])
}

// ─── ИИ-ассистент: Справочники ────────────────────────────────────────────────

model CrmStatus {
  id       String      @id @default(cuid())
  name     String
  color    String      @default("#6366f1")
  order    Int         @default(0)
  archived Boolean     @default(false)
  clients  VkClient[]
}

model Tag {
  id       String      @id @default(cuid())
  name     String
  color    String      @default("#10b981")
  archived Boolean     @default(false)
  clients  ClientTag[]
}

model ClientTag {
  clientId String
  tagId    String
  client   VkClient @relation(fields: [clientId], references: [id], onDelete: Cascade)
  tag      Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([clientId, tagId])
}

model OrderStatus {
  id       String   @id @default(cuid())
  name     String
  color    String   @default("#f59e0b")
  order    Int      @default(0)
  archived Boolean  @default(false)
  orders   Order[]
}

// ─── ИИ-ассистент: Заказы ─────────────────────────────────────────────────────

model Order {
  id            String       @id @default(cuid())
  number        Int          @default(autoincrement())
  clientId      String
  client        VkClient     @relation(fields: [clientId], references: [id])
  orderStatusId String?
  orderStatus   OrderStatus? @relation(fields: [orderStatusId], references: [id])
  amount        Float?
  items         String?
  comment       String?
  createdAt     DateTime     @default(now())
  archived      Boolean      @default(false)

  @@index([clientId])
  @@index([createdAt])
}

// ─── ИИ-ассистент: Быстрые фразы ─────────────────────────────────────────────

model PhraseCategory {
  id       String       @id @default(cuid())
  name     String
  order    Int          @default(0)
  archived Boolean      @default(false)
  phrases  QuickPhrase[]
}

model QuickPhrase {
  id         String         @id @default(cuid())
  categoryId String
  category   PhraseCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  title      String
  text       String
  hotkey     String?
  order      Int            @default(0)
  archived   Boolean        @default(false)
}

// ─── ИИ-ассистент: Рассылки ───────────────────────────────────────────────────

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  DONE
  PAUSED
  FAILED
}

enum RecipientStatus {
  PENDING
  SENT
  ERROR
  SKIPPED
}

model Campaign {
  id             String         @id @default(cuid())
  name           String
  channel        String         @default("VK")
  messageText    String
  attachments    Json           @default("[]")
  segmentFilter  Json           @default("{}")
  audienceType   String         @default("filter")
  audienceConfig Json           @default("{}")
  status         CampaignStatus @default(DRAFT)
  scheduledAt    DateTime?
  createdAt      DateTime       @default(now())
  totalCount     Int            @default(0)
  sentCount      Int            @default(0)
  errorCount     Int            @default(0)
  archived       Boolean        @default(false)
  description    String         @default("")
  recipients     CampaignRecipient[]

  @@index([status, archived])
  @@index([createdAt])
}

model CampaignRecipient {
  id         String          @id @default(cuid())
  campaignId String
  campaign   Campaign        @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  peerId     Int
  clientName String          @default("")
  status     RecipientStatus @default(PENDING)
  sentAt     DateTime?
  error      String?

  @@index([campaignId, status])
}

// ─── ИИ-ассистент: Настройки ИИ ──────────────────────────────────────────────

model AiSettings {
  id           String   @id @default("default")
  systemPrompt String   @default("")
  provider     String   @default("openai")
  model        String   @default("claude-haiku-4-5-20251001")
  temperature  Float    @default(0.7)
  draftMode    Boolean  @default(true)
  updatedAt    DateTime @updatedAt
}

model AiKnowledgeEntry {
  id        String   @id @default(cuid())
  category  String   @default("general")
  title     String
  content   String
  enabled   Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

// ─── ИИ-ассистент: Боты ───────────────────────────────────────────────────────

enum BotType {
  RULE
  SCENARIO
}

enum BotStepType {
  TRIGGER
  SEND_MESSAGE
  SET_CRM_STATUS
  SET_TAGS
  SET_ORDER_STATUS
  MARK_IMPORTANT
  EXTRACT_FIELD
  SET_REMINDER
  ASSIGN_MANAGER
  NOTIFY_MANAGER
  LOG_STAT
  CONDITION
  DELAY
  END_SCENARIO
  UNSUBSCRIBE
  GOTO_STEP
}

enum ScenarioStateStatus {
  ACTIVE
  WAITING_DELAY
  DONE
  CANCELLED
}

model Bot {
  id        String   @id @default(cuid())
  name      String
  type      BotType  @default(RULE)
  enabled   Boolean  @default(false)
  archived  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  steps  BotStep[]
  states ClientScenarioState[]
  logs   BotLog[]
}

model BotStep {
  id         String      @id @default(cuid())
  botId      String
  bot        Bot         @relation(fields: [botId], references: [id], onDelete: Cascade)
  type       BotStepType
  config     Json        @default("{}")
  position   Int         @default(0)
  nextStepId String?
  branches   Json        @default("[]")
  createdAt  DateTime    @default(now())

  @@index([botId, position])
}

model ClientScenarioState {
  id            String              @id @default(cuid())
  clientId      String
  client        VkClient            @relation(fields: [clientId], references: [id], onDelete: Cascade)
  botId         String
  bot           Bot                 @relation(fields: [botId], references: [id], onDelete: Cascade)
  currentStepId String?
  vars          Json                @default("{}")
  status        ScenarioStateStatus @default(ACTIVE)
  scheduledAt   DateTime?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@index([clientId, botId])
  @@index([status, scheduledAt])
}

model BotLog {
  id        String   @id @default(cuid())
  botId     String
  bot       Bot      @relation(fields: [botId], references: [id], onDelete: Cascade)
  clientId  String?
  peerId    Int?
  event     String
  action    String
  result    String?
  createdAt DateTime @default(now())

  @@index([botId, createdAt])
}

// ─── Finance (ДДС + ПНЛ) ─────────────────────────────────────────────────────

enum FinProject {
  EASYBOOK
  EASYNEON
  IZIBANYA
  GENERAL
}

enum FinAccountType {
  BANK
  SAVINGS
  CASH
  CREDIT
}

enum FinOpType {
  INCOME
  EXPENSE
  TRANSFER
  LOAN_PRINCIPAL
  DEPOSIT_PLACE
  DEPOSIT_RETURN
  DIVIDEND
}

enum FinOpSource {
  MANUAL
  BANK_IMPORT
  CDEK_IMPORT
}

enum FinOrderStatus {
  PREPAY
  PAID_50
  SHIPPED
  DELIVERED
  REFUNDED
}

enum AccrualType {
  REVENUE
  OPEX
  REFUND
  ADVANCE
  CDEK_FEE
  CDEK_RECEIVABLE
}

model FinAccount {
  id             String         @id @default(cuid())
  name           String
  type           FinAccountType @default(BANK)
  openingBalance Int            @default(0)
  currentBalance Int            @default(0)
  currency       String         @default("RUB")
  archived       Boolean        @default(false)
  order          Int            @default(0)
  createdAt      DateTime       @default(now())
  operations     FinOperation[]

  @@index([archived, order])
}

model FinCategory {
  id            String           @id @default(cuid())
  name          String
  type          String
  group         String?
  isPnl         Boolean          @default(true)
  archived      Boolean          @default(false)
  order         Int              @default(0)
  subcategories FinSubcategory[]
  operations    FinOperation[]
}

model FinSubcategory {
  id         String         @id @default(cuid())
  categoryId String
  category   FinCategory    @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  name       String
  archived   Boolean        @default(false)
  order      Int            @default(0)
  operations FinOperation[]
}

model FinOperation {
  id              String          @id @default(cuid())
  date            DateTime
  accountId       String
  account         FinAccount      @relation(fields: [accountId], references: [id])
  amountKopecks   Int
  type            FinOpType       @default(INCOME)
  categoryId      String?
  category        FinCategory?    @relation(fields: [categoryId], references: [id])
  subcategoryId   String?
  subcategory     FinSubcategory? @relation(fields: [subcategoryId], references: [id])
  project         FinProject?
  counterparty    String?
  comment         String?
  isPnl           Boolean         @default(true)
  source          FinOpSource     @default(MANUAL)
  externalId      String?
  linkedAccountId String?
  finOrderId      String?
  finOrder        FinOrder?       @relation(fields: [finOrderId], references: [id])
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@unique([source, externalId])
  @@index([date])
  @@index([accountId, date])
  @@index([project, date])
  @@index([type, date])
}

model FinOrder {
  id                  String         @id @default(cuid())
  clientRef           String?
  vkClientId          String?
  project             FinProject     @default(EASYBOOK)
  totalAmountKopecks  Int            @default(0)
  prepayKopecks       Int            @default(0)
  paidKopecks         Int            @default(0)
  cdekFeeKopecks      Int            @default(0)
  status              FinOrderStatus @default(PREPAY)
  shippedAt           DateTime?
  revenueRecognizedAt DateTime?
  cdekTrackNumber     String?
  comment             String?
  archived            Boolean        @default(false)
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  operations     FinOperation[]
  accrualEntries AccrualEntry[]

  @@index([status])
  @@index([shippedAt])
  @@index([project])
}

model AccrualEntry {
  id            String      @id @default(cuid())
  period        DateTime
  type          AccrualType
  amountKopecks Int
  project       FinProject  @default(EASYBOOK)
  finOrderId    String?
  finOrder      FinOrder?   @relation(fields: [finOrderId], references: [id])
  description   String?
  createdAt     DateTime    @default(now())

  @@index([period, project])
  @@index([type, period])
}
