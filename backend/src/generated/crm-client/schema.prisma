  runtimePauseReason String?
  vkAdGroupId        Int?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  variants           VkAdsTestVariant[]

  @@index([testId])
  @@index([status])
  @@index([vkSegmentId])
  @@index([vkAdGroupId])
}

model VkAdsTestCreative {
  id             Int                  @id @default(autoincrement())
  testId         Int
  test           VkAdsTest            @relation(fields: [testId], references: [id], onDelete: Cascade)
  videoAssetId   Int?
  videoAsset     VkAdsTestVideoAsset? @relation(fields: [videoAssetId], references: [id], onDelete: SetNull)
  name           String
  title          String
  text           String
  videoSourceUrl String?
  vkContentId    String?
  status         String               @default("draft")
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  variants       VkAdsTestVariant[]

  @@index([testId])
  @@index([status])
  @@index([videoAssetId])
}

model VkAdsTestVideoAsset {
  id                   Int                     @id @default(autoincrement())
  testId               Int
  test                 VkAdsTest               @relation(fields: [testId], references: [id], onDelete: Cascade)
  accountIntegrationId Int
  accountIntegration   VkAdsAccountIntegration @relation(fields: [accountIntegrationId], references: [id], onDelete: Restrict)
  vkContentId          Int
  name                 String?
  rawContentJson       Json
  previewUrl           String?
  videoUrl             String?
  width                Int?
  height               Int?
  durationSec          Int?
  status               String                  @default("processing")
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt
  creatives            VkAdsTestCreative[]

  @@index([testId])
  @@index([accountIntegrationId])
  @@index([vkContentId])
  @@index([status])
}

model VkAdsTestVariant {
  id                 Int                  @id @default(autoincrement())
  testId             Int
  test               VkAdsTest            @relation(fields: [testId], references: [id], onDelete: Cascade)
  audienceId         Int
  audience           VkAdsTestAudience    @relation(fields: [audienceId], references: [id], onDelete: Cascade)
  creativeId         Int
  creative           VkAdsTestCreative    @relation(fields: [creativeId], references: [id], onDelete: Cascade)
  variantKey         String               @unique
  ref                String?
  status             String               @default("draft")
  budgetLimitDay     Decimal              @db.Decimal(12, 2)
  runtimePauseReason String?
  vkCampaignId       Int?
  vkAdGroupId        Int?
  vkBannerId         Int?
  vkPrimaryUrlId     Int?
  launchDate         DateTime?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  actionLogs         VkAdsTestActionLog[]

  @@unique([testId, creativeId, audienceId])
  @@index([testId])
  @@index([audienceId])
  @@index([creativeId])
  @@index([status])
  @@index([vkCampaignId])
  @@index([vkAdGroupId])
  @@index([vkBannerId])
  @@index([vkPrimaryUrlId])
  @@index([ref])
}

model VkAdsTestActionLog {
  id          Int               @id @default(autoincrement())
  testId      Int
  test        VkAdsTest         @relation(fields: [testId], references: [id], onDelete: Cascade)
  variantId   Int?
  variant     VkAdsTestVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  action      String
  reason      String?
  payloadJson Json?
  createdAt   DateTime          @default(now())

  @@index([testId])
  @@index([variantId])
  @@index([action])
}

model PnlSnapshot {
  id           Int      @id @default(autoincrement())
  type         String
  anchorPeriod String
  payload      Json
  version      Int      @default(1)
  computedAt   DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([type, anchorPeriod], map: "pnl_snapshot_unique_type_period")
  @@index([type, computedAt])
}

model AssistantProfile {
  id                       Int                             @id @default(autoincrement())
  crmAccountId             Int                             @unique
  account                  CrmAccount                      @relation(fields: [crmAccountId], references: [id], onDelete: Cascade)
  profileKey               String
  isActive                 Boolean                         @default(true)
  maxChars                 Int                             @default(500)
  debounceMs               Int                             @default(7000)
  quickPhrasesContextLimit Int                             @default(10)
  createdAt                DateTime                        @default(now())
  updatedAt                DateTime                        @updatedAt
  threads                  AssistantVkThread[]
  drafts                   AssistantReplyDraft[]
  events                   AssistantCustomerEvent[]
  allowedStatuses          AssistantProfileAllowedStatus[]

  @@index([profileKey])
}

model AssistantProfileAllowedStatus {
  id                 Int              @id @default(autoincrement())
  assistantProfileId Int
  crmStatusId        Int
  assistantProfile   AssistantProfile @relation(fields: [assistantProfileId], references: [id], onDelete: Cascade)
  crmStatus          CrmStatus        @relation(fields: [crmStatusId], references: [id], onDelete: Cascade)
  createdAt          DateTime         @default(now())

  @@unique([assistantProfileId, crmStatusId])
  @@index([crmStatusId])
}

model AssistantVkThread {
  id                      Int                      @id @default(autoincrement())
  assistantProfileId      Int
  assistantProfile        AssistantProfile         @relation(fields: [assistantProfileId], references: [id])
  crmAccountId            Int
  account                 CrmAccount               @relation(fields: [crmAccountId], references: [id])
  crmCustomerId           Int
  customer                CrmCustomer              @relation(fields: [crmCustomerId], references: [id])
  vkPeerId                String
  codexThreadId           String?
  dialogSummary           String?
  lastAnalyzedMessageId   String?
  lastContextHash         String?
  contextStartVkMessageId String?
  status                  String                   @default("active")
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  drafts                  AssistantReplyDraft[]
  events                  AssistantCustomerEvent[]

  @@unique([crmAccountId, crmCustomerId, vkPeerId])
  @@index([crmAccountId, vkPeerId])
  @@index([crmCustomerId])
  @@index([assistantProfileId])
  @@index([status])
}

model AssistantReplyDraft {
  id                   Int                      @id @default(autoincrement())
  assistantProfileId   Int
  assistantProfile     AssistantProfile         @relation(fields: [assistantProfileId], references: [id])
  assistantThreadId    Int
  assistantThread      AssistantVkThread        @relation(fields: [assistantThreadId], references: [id])
  crmAccountId         Int
  account              CrmAccount               @relation(fields: [crmAccountId], references: [id])
  crmCustomerId        Int
  customer             CrmCustomer              @relation(fields: [crmCustomerId], references: [id])
  vkPeerId             String
  requestId            String                   @unique
  triggerVkMessageIds  Json?
  contextHash          String?
  contextSnapshotJson  Json?
  status               String
  draftText            String?
  finalText            String?
  errorCode            String?
  errorMessage         String?
  brainVersion         String?
  promptVersion        String?
  codexThreadId        String?
  durationMs           Int?
  proposedStatusId     Int?
  proposedStatusCode   String?
  proposedStatusReason String?
  phraseId             Int?
  managerId            Int?
  managerDecidedAt     DateTime?
  rejectionReason      String?
  generationStartedAt  DateTime?
  generationFinishedAt DateTime?
  createdAt            DateTime                 @default(now())
  updatedAt            DateTime                 @updatedAt
  events               AssistantCustomerEvent[]

  @@index([assistantThreadId, createdAt])
  @@index([crmAccountId, status])
  @@index([crmCustomerId, status])
  @@index([vkPeerId, status])
}

model AssistantCustomerEvent {
  id                    Int                  @id @default(autoincrement())
  assistantProfileId    Int
  assistantProfile      AssistantProfile     @relation(fields: [assistantProfileId], references: [id])
  assistantThreadId     Int?
  assistantThread       AssistantVkThread?   @relation(fields: [assistantThreadId], references: [id])
  assistantReplyDraftId Int?
  assistantReplyDraft   AssistantReplyDraft? @relation(fields: [assistantReplyDraftId], references: [id])
  crmAccountId          Int
  account               CrmAccount           @relation(fields: [crmAccountId], references: [id])
  crmCustomerId         Int
  customer              CrmCustomer          @relation(fields: [crmCustomerId], references: [id])
  vkPeerId              String?
  eventType             String
  payload               Json
  createdAt             DateTime             @default(now())

  @@index([crmCustomerId, createdAt])
  @@index([crmAccountId, eventType])
  @@index([assistantThreadId])
  @@index([assistantReplyDraftId])
}
