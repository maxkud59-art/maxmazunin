// Отдельный Prisma-клиент для CRM-данных (read-only explorer).
// БД: crm_explorer (локально) / отдельная БД на продакшн-сервере.
// Генерация: npm run db:generate:crm

generator crmClient {
  provider = "prisma-client-js"
  output   = "../src/generated/crm-client"
}

datasource db {
  provider = "postgresql"
  url      = env("CRM_DATABASE_URL")
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  expiresAt DateTime
  revoked   Boolean  @default(false)

  @@index([userId])
}

model Project {
  id        Int      @id @default(autoincrement())
  name      String
  code      String?  @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  groups Group[]
  boards Board[]

  operationPositions       OperationPosition[]
  counterPartiesIncome     CounterParty[]            @relation("CounterPartyIncomeProject")
  counterPartiesOutcome    CounterParty[]            @relation("CounterPartyOutcomeProject")
  vkAdsAccountIntegrations VkAdsAccountIntegration[]
  adSources                AdSource[]
}

model WorkSpace {
  id                Int                @id @default(autoincrement())
  title             String             @unique
  department        String
  deletedAt         DateTime?
  createdAt         DateTime           @default(now())
  groups            Group[]
  users             User[]
  clients           Client[]
  deals             Deal[]
  dops              Dop[]
  payments          Payment[]
  dealSources       DealSource[]
  adSources         AdSource[]
  reports           RopReport[]
  rovReports        RovReport[]
  adExpenses        AdExpense[]
  salaryPays        salaryPay[]
  salaryCorrections salaryCorrection[]
  deliveries        Delivery[]
}

model Group {
  id        Int       @id @default(autoincrement())
  title     String
  deletedAt DateTime?
  createdAt DateTime  @default(now())

  projectId Int?
  project   Project? @relation(fields: [projectId], references: [id])

  workSpaceId Int
  workSpace   WorkSpace @relation(fields: [workSpaceId], references: [id])

  users      User[]
  clients    Client[]
  deals      Deal[]
  dops       Dop[]
  payments   Payment[]
  reports    RopReport[]
  rovReports RovReport[]
  adExpenses AdExpense[]
  adSources  AdSource[]

  @@index([projectId])
}

model Role {
  id         Int       @id @default(autoincrement())
  shortName  String    @unique
  fullName   String
  department String
  deletedAt  DateTime?
  createdAt  DateTime  @default(now())
  users      User[]
}

model User {
  id        Int       @id @default(autoincrement())
  fullName  String
  email     String    @unique
  password  String
  info      String    @default("")
  tg        String    @default("")
  tg_id     String    @default("")
  status    String    @default("")
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  avatarUrl String?

  refreshTokens RefreshToken[]

  roleId   Int
  role     Role    @relation(fields: [roleId], references: [id])
  isIntern Boolean @default(false)

  workSpaceId Int
  workSpace   WorkSpace @relation(fields: [workSpaceId], references: [id])

  groupId Int
  group   Group @relation(fields: [groupId], references: [id])

  clients   Client[]
  deals     Deal[]
  dealSales DealUser[]
  dealAudit DealAudit[]

  payments            Payment[]
  dops                Dop[]
  deliveries          Delivery[]
  reviews             Review[]
  uploadLinkActions   UploadLinkAction[]
  managersPlans       ManagersPlan[]
  managerReports      ManagerReport[]
  salaryPays          salaryPay[]
  salaryCorrections   salaryCorrection[]
  masterReports       MasterReport[]
  masterRepairReports MasterRepairReport[]
  packerReports       PackerReport[]
  masterShifts        MasterShift[]
  packerShifts        PackerShift[]
  logistShifts        LogistShift[]
  washerShifts        WasherShift[]
  printerShifts       PrinterShift[]
  otherReport         OtherReport[]
  frezerReports       FrezerReport[]

  boards              Board[]              @relation("BoardUsers")
  tasks               KanbanTask[]         @relation("TaskMembers")
  createdTasks        KanbanTask[]         @relation("TaskCreator")
  comments            KanbanTaskComments[]
  audits              KanbanTaskAudit[]
  uploadedFiles       KanbanFile[]         @relation("KanbanFileUploader")
  columnSubscriptions ColumnSubscription[]
}

model ManagersPlan {
  id        Int       @id @default(autoincrement())
  period    String
  plan      Int       @default(0)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  userId    Int
  user      User      @relation(fields: [userId], references: [id])
}

model ManagerReport {
  id             Int     @id @default(autoincrement())
  calls          Int     @default(0)
  makets         Int     @default(0)
  maketsDayToDay Int     @default(0)
  date           String
  period         String  @default("")
  redirectToMSG  Int     @default(0)
  shiftCost      Float   @default(666.67)
  isIntern       Boolean @default(false)
  userId         Int
  user           User    @relation(fields: [userId], references: [id])
}

model RopReport {
  id             Int       @id @default(autoincrement())
  calls          Int       @default(0)
  makets         Int       @default(0)
  maketsDayToDay Int       @default(0)
  redirectToMSG  Int       @default(0)
  date           String
  period         String    @default("")
  workSpaceId    Int
  workSpace      WorkSpace @relation(fields: [workSpaceId], references: [id])
  groupId        Int?
  group          Group?    @relation(fields: [groupId], references: [id])
}

model RovReport {
  id               Int       @id @default(autoincrement())
  date             String
  takenToDesign    Int       @default(0)
  sentToProduction Int       @default(0)
  workSpaceId      Int
  workSpace        WorkSpace @relation(fields: [workSpaceId], references: [id])
  groupId          Int
  group            Group     @relation(fields: [groupId], references: [id])

  @@unique([groupId, date])
  @@index([workSpaceId])
}

model salaryPay {
  id          Int       @id @default(autoincrement())
  date        String    @default("")
  period      String    @default("")
  price       Int
  status      String
  userId      Int
  user        User      @relation(fields: [userId], references: [id])
  workSpaceId Int
  workSpace   WorkSpace @relation(fields: [workSpaceId], references: [id])
}

model salaryCorrection {
  id          Int       @id @default(autoincrement())
  date        String    @default("")
  period      String    @default("")
  price       Int
  type        String
  description String    @default("")
  userId      Int
  user        User      @relation(fields: [userId], references: [id])
  workSpaceId Int
  workSpace   WorkSpace @relation(fields: [workSpaceId], references: [id])
}

model Client {
  id           Int       @id @default(autoincrement())
  fullName     String
  phone        String    @default("")
  chatLink     String    @unique
  adLink       String    @default("")
  gender       String
  type         String
  inn          String    @default("")
  info         String    @default("")
  firstContact String
  isRegular    Boolean   @default(false)
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())
  workSpaceId  Int
  workSpace    WorkSpace @relation(fields: [workSpaceId], references: [id])
  groupId      Int
  group        Group     @relation(fields: [groupId], references: [id])
  userId       Int
  user         User      @relation(fields: [userId], references: [id])
  deals        Deal[]
}

model Deal {
  id                Int       @id @default(autoincrement())
  saleDate          String
  card_id           String    @default("")
  title             String
  price             Int
  status            String    @default("Создана")
  clothingMethod    String
  description       String    @default("")
  source            String
  adTag             String
  discont           String
  sphere            String    @default("")
  city              String    @default("")
  region            String    @default("")
  paid              Boolean   @default(false)
  maketType         String    @default("")
  category          String    @default("")
  maketPresentation String    @default("")
  period            String    @default("")
  deletedAt         DateTime?
  createdAt         DateTime  @default(now())
  reservation       Boolean   @default(false)
  bookSize          String    @default("")
  pageType          String    @default("")
  pages             Int       @default(0)
  courseType        String    @default("")
  discontAmount     Int       @default(0)

  workSpaceId         Int
  workSpace           WorkSpace            @relation(fields: [workSpaceId], references: [id])
  groupId             Int
  group               Group                @relation(fields: [groupId], references: [id])
  userId              Int
  user                User                 @relation(fields: [userId], references: [id])
  dealers             DealUser[]
  clientId            Int
  client              Client               @relation(fields: [clientId], references: [id])
  payments            Payment[]
  dops                Dop[]
  deliveries          Delivery[]
  reviews             Review[]
  orders              TaskOrder[]
  tasks               KanbanTask[]
  statusHistory       DealStatusHistory[]
  audit               DealAudit[]
  masterReports       MasterReport[]
  masterRepairReports MasterRepairReport[]
  packerReports       PackerReport[]
  otherReports        OtherReport[]

  @@index([saleDate, groupId])
}

model DealStatusHistory {
  id        Int      @id @default(autoincrement())
  status    String
  changedAt DateTime @default(now())
  comment   String?
  dealId    Int
  deal      Deal     @relation(fields: [dealId], references: [id])
}

model DealAudit {
  id        Int      @id @default(autoincrement())
  action    String
  comment   String?
  createdAt DateTime @default(now())
  dealId    Int
  deal      Deal     @relation(fields: [dealId], references: [id])
  userId    Int?
  user      User?    @relation(fields: [userId], references: [id])
}

model UploadLinkAction {
  id                       Int      @id @default(autoincrement())
  filePlatformUploadLinkId String
  token                    String
  publicUrl                String
  source                   String
  createdAt                DateTime @default(now())
  createdByUserId          Int
  createdByUser            User     @relation(fields: [createdByUserId], references: [id], onDelete: Restrict)

  @@index([createdByUserId, createdAt])
  @@index([source, createdAt])
}

model AdSource {
  id               Int                      @id @default(autoincrement())
  title            String                   @unique
  adExpenses       AdExpense[]
  workSpaceId      Int
  workSpace        WorkSpace                @relation(fields: [workSpaceId], references: [id])
  groupId          Int?
  group            Group?                   @relation(fields: [groupId], references: [id])
  projectId        Int?
  project          Project?                 @relation(fields: [projectId], references: [id], onDelete: SetNull)
  vkAdsIntegration VkAdsAccountIntegration?

  @@index([projectId])
}

model DealSource {
  id          Int       @id @default(autoincrement())
  title       String    @unique
  workSpaceId Int
  workSpace   WorkSpace @relation(fields: [workSpaceId], references: [id])
}

model AdExpense {
  id           Int       @id @default(autoincrement())
  price        Int       @default(0)
  date         String
  period       String    @default("")
  vkAdsSyncKey String?   @unique
  adSourceId   Int
  adSource     AdSource  @relation(fields: [adSourceId], references: [id])
  workSpaceId  Int
  workSpace    WorkSpace @relation(fields: [workSpaceId], references: [id])
  groupId      Int?
  group        Group?    @relation(fields: [groupId], references: [id])
}

model ClothingMethod {
  id    Int    @id @default(autoincrement())
  title String @unique
}

model AdTag {
  id    Int    @id @default(autoincrement())
  title String @unique
}

model Sphere {
  id    Int    @id @default(autoincrement())
  title String @unique
}

model DealUser {
  id     Int  @id @default(autoincrement())
  price  Int
  idx    Int  @default(0)
  dealId Int
  deal   Deal @relation(fields: [dealId], references: [id])
  userId Int
  user   User @relation(fields: [userId], references: [id])

  @@unique([dealId, userId])
}

model Payment {
  id          Int       @id @default(autoincrement())
  title       String
  price       Int
  date        String
  method      String
  description String    @default("")
  reservation Boolean   @default(false)
  period      String    @default("")
  stutus      String    @default("")
  paymentId   String    @default("")
  paymentLink String    @default("")
  isConfirmed Boolean   @default(true)
  terminal    String    @default("")
  userId      Int
  user        User      @relation(fields: [userId], references: [id])
  dealId      Int
  deal        Deal      @relation(fields: [dealId], references: [id])
  workSpaceId Int
  workspace   WorkSpace @relation(fields: [workSpaceId], references: [id])
  groupId     Int?
  group       Group?    @relation(fields: [groupId], references: [id])
}

model Dop {
  id          Int       @id @default(autoincrement())
  saleDate    String
  type        String
  price       Int
  description String    @default("")
  period      String    @default("")
  userId      Int
  user        User      @relation(fields: [userId], references: [id])
  dealId      Int
  deal        Deal      @relation(fields: [dealId], references: [id])
  workSpaceId Int
  workSpace   WorkSpace @relation(fields: [workSpaceId], references: [id])
  groupId     Int?
  group       Group?    @relation(fields: [groupId], references: [id])

  @@index([saleDate, groupId])
  @@index([dealId])
}

model DopsType {
  id    Int    @id @default(autoincrement())
  title String @unique
}

model Delivery {
  id            Int         @id @default(autoincrement())
  date          String      @default("")
  method        String      @default("")
  type          String      @default("")
  purpose       String      @default("")
  description   String      @default("")
  track         String      @default("")
  status        String      @default("")
  price         Float       @default(0)
  deliveredDate String      @default("")
  cdekStatus    String?
  deletedAt     DateTime?
  dealId        Int
  deal          Deal        @relation(fields: [dealId], references: [id])
  taskId        Int?
  task          KanbanTask? @relation(fields: [taskId], references: [id], onDelete: SetNull)
  workSpaceId   Int?
  workSpace     WorkSpace?  @relation(fields: [workSpaceId], references: [id])
  userId        Int?
  user          User?       @relation(fields: [userId], references: [id])

  @@index([taskId])
  @@index([date])
  @@index([dealId])
}

model Review {
  id     Int    @id @default(autoincrement())
  date   String
  userId Int
  user   User   @relation(fields: [userId], references: [id])
  dealId Int
  deal   Deal   @relation(fields: [dealId], references: [id])
  file   File[]
}

model File {
  id        Int    @id @default(autoincrement())
  name      String @default("")
  ya_name   String @default("")
  size      Int    @default(0)
  preview   String @default("")
  path      String @default("")
  directory String @default("")
  reviewId  Int
  review    Review @relation(fields: [reviewId], references: [id])
}

model Supplie {
  id             Int               @id @default(autoincrement())
  date           String
  shipmentDate   String            @default("")
  supplier       String
  paymentMethod  String
  orderStatus    String
  paymentStatus  String
  deliveryMethod String
  invoice        String?
  track          String?
  positions      SuppliePosition[]

  @@index([shipmentDate])
}

model SuppliePosition {
  id           Int     @id @default(autoincrement())
  name         String
  priceForItem Float
  quantity     Decimal
  category     String  @default("")
  supplieId    Int
  supplie      Supplie @relation(fields: [supplieId], references: [id])

  @@index([category, supplieId])
  @@index([supplieId])
}

model Suppliers {
  id   Int    @id @default(autoincrement())
  name String @unique
}

model SuppliesCategories {
  id   Int    @id @default(autoincrement())
  name String
}

model MasterRepairReport {
  id           Int       @id @default(autoincrement())
  date         String
  name         String
  grinding     Int       @default(0)
  unpackage    Int       @default(0)
  unpackageBig Int       @default(0)
  smartContr   Int       @default(0)
  acoustics    Int       @default(0)
  metrs        Float     @default(0)
  els          Int       @default(0)
  penaltyCost  Int       @default(0)
  deletedAt    DateTime?
  type         String
  cost         Int
  isPenalty    Boolean   @default(false)
  comment      String    @default("")
  userId       Int
  user         User      @relation(fields: [userId], references: [id])
  dealId       Int?
  deal         Deal?     @relation(fields: [dealId], references: [id])
}

model MasterReport {
  id               Int       @id @default(autoincrement())
  date             String
  name             String
  metrs            Float
  els              Int
  type             String
  cost             Int
  penaltyCost      Int       @default(0)
  isPenalty        Boolean   @default(false)
  comment          String    @default("")
  lightingType     String    @default("")
  lightingLength   Float     @default(0)
  lightingElements Int       @default(0)
  lightingCost     Int       @default(0)
  deletedAt        DateTime?
  userId           Int
  user             User      @relation(fields: [userId], references: [id])
  dealId           Int?
  deal             Deal?     @relation(fields: [dealId], references: [id])
  orderId          Int?
}

model PackerReport {
  id          Int       @id @default(autoincrement())
  date        String
  name        String
  overSize    Boolean
  isGift      Boolean
  items       Int
  adapters    Int       @default(0)
  lam         Int       @default(0)
  cost        Int
  dimmers     Int
  dops        Int       @default(0)
  dopsComment String    @default("")
  deletedAt   DateTime?
  isPenalty   Boolean   @default(false)
  comment     String    @default("")
  penaltyCost Int       @default(0)
  userId      Int
  user        User      @relation(fields: [userId], references: [id])
  dealId      Int?
  deal        Deal?     @relation(fields: [dealId], references: [id])
  taskId      Int?
}

model MasterShift {
  id         Int    @id @default(autoincrement())
  shift_date String
  userId     Int
  user       User   @relation(fields: [userId], references: [id])
}

model PackerShift {
  id         Int    @id @default(autoincrement())
  shift_date String
  userId     Int
  user       User   @relation(fields: [userId], references: [id])
}

model LogistShift {
  id         Int    @id @default(autoincrement())
  shift_date String
  cost       Int    @default(0)
  userId     Int
  user       User   @relation(fields: [userId], references: [id])
}

model WasherShift {
  id         Int    @id @default(autoincrement())
  shift_date String
  cost       Int    @default(0)
  userId     Int
  user       User   @relation(fields: [userId], references: [id])

  @@index([userId, shift_date])
}

model PrinterShift {
  id         Int    @id @default(autoincrement())
  shift_date String
  cost       Int    @default(0)
  userId     Int
  user       User   @relation(fields: [userId], references: [id])

  @@index([userId, shift_date])
}

model OtherReport {
  id          Int       @id @default(autoincrement())
  date        String
  name        String
  cost        Int
  penaltyCost Int       @default(0)
  comment     String    @default("")
  deletedAt   DateTime?
  userId      Int
  user        User      @relation(fields: [userId], references: [id])
  dealId      Int?
  deal        Deal?     @relation(fields: [dealId], references: [id])
  taskId      Int?
}

model FrezerReport {
  id          Int    @id @default(autoincrement())
  date        String
  items       Int    @default(0)
  sheets      Float  @default(0)
  remake      Float  @default(0)
  hours       Int    @default(0)
  cost        Int    @default(0)
  square      Float  @default(0)
  comment     String @default("")
  penaltyCost Int    @default(0)
  userId      Int
  user        User   @relation(fields: [userId], references: [id])
}

model ExpenseCategory {
  id                    Int                   @id @default(autoincrement())
  name                  String
  type                  String
  description           String?
  parentId              Int?
  parent                ExpenseCategory?      @relation("CategoryRelation", fields: [parentId], references: [id], onDelete: SetNull)
  children              ExpenseCategory[]     @relation("CategoryRelation")
  groupId               Int?
  group                 ExpenseCategoryGroup? @relation(fields: [groupId], references: [id], onDelete: SetNull)
  sortOrder             Int                   @default(0)
  counterPartiesIncome  CounterParty[]        @relation("CounterPartyIncome")
  counterPartiesOutcome CounterParty[]        @relation("CounterPartyOutcome")
  operationPositions    OperationPosition[]
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  deletedAt             DateTime?

  @@index([groupId])
}

model ExpenseCategoryGroup {
  id         Int               @id @default(autoincrement())
  name       String
  type       String
  sortOrder  Int               @default(0)
  collapsed  Boolean           @default(false)
  categories ExpenseCategory[]
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  deletedAt  DateTime?

  @@index([type])
}

model PlanFactAccount {
  id                 Int                          @id @default(autoincrement())
  name               String
  accountNumber      String                       @unique
  balance            Float                        @default(0)
  type               String                       @default("")
  balanceStartDate   String                       @default("")
  comment            String                       @default("")
  isReal             Boolean                      @default(true)
  operations         Operation[]
  originalOperations OriginalOperationFromTbank[]
  syncStatus         TbankSyncStatus?
}

model Operation {
  id                 Int                 @id @default(autoincrement())
  operationId        String              @unique
  operationDate      String
  operationDateTime  DateTime
  typeOfOperation    String              @default("")
  operationType      String              @default("")
  category           String              @default("")
  description        String              @default("")
  payPurpose         String              @default("")
  isCreated          Boolean             @default(false)
  accountId          Int
  account            PlanFactAccount     @relation(fields: [accountId], references: [id])
  operationPositions OperationPosition[]
  updatedAt          DateTime            @updatedAt
  deletedAt          DateTime?
}

model CounterParty {
  id                       Int                 @id @default(autoincrement())
  title                    String
  type                     String              @default("")
  inn                      String              @default("")
  kpp                      String              @default("")
  account                  String              @default("")
  bankBic                  String              @default("")
  bankName                 String              @default("")
  contrAgentGroup          String              @default("")
  operationPositions       OperationPosition[]
  incomeExpenseCategoryId  Int?
  incomeExpenseCategory    ExpenseCategory?    @relation("CounterPartyIncome", fields: [incomeExpenseCategoryId], references: [id])
  outcomeExpenseCategoryId Int?
  outcomeExpenseCategory   ExpenseCategory?    @relation("CounterPartyOutcome", fields: [outcomeExpenseCategoryId], references: [id])
  incomeProjectId          Int?
  incomeProject            Project?            @relation("CounterPartyIncomeProject", fields: [incomeProjectId], references: [id])
  outcomeProjectId         Int?
  outcomeProject           Project?            @relation("CounterPartyOutcomeProject", fields: [outcomeProjectId], references: [id])

  @@index([incomeProjectId])
  @@index([outcomeProjectId])
}

model AutoCategoryRule {
  id                Int      @id @default(autoincrement())
  enabled           Boolean  @default(true)
  priority          Int      @default(100)
  name              String
  description       String   @default("")
  keywords          String[]
  operationType     String
  accountIds        Int[]
  counterPartyIds   Int[]
  expenseCategoryId Int
  projectId         Int?
  effectiveFrom     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([enabled, priority])
}

model OperationPosition {
  id                  Int                         @id @default(autoincrement())
  amount              Float
  period              String?
  source              String                      @default("MANUAL")
  operationId         Int?
  operation           Operation?                  @relation(fields: [operationId], references: [id])
  originalOperationId Int?
  originalOperation   OriginalOperationFromTbank? @relation(fields: [originalOperationId], references: [id])
  counterPartyId      Int?
  counterParty        CounterParty?               @relation(fields: [counterPartyId], references: [id])
  expenseCategoryId   Int?
  expenseCategory     ExpenseCategory?            @relation(fields: [expenseCategoryId], references: [id])
  projectId           Int?
  project             Project?                    @relation(fields: [projectId], references: [id])

  @@index([originalOperationId])
  @@index([operationId])
  @@index([counterPartyId])
  @@index([expenseCategoryId])
  @@index([projectId])
}

model OriginalOperationFromTbank {
  id                   Int                 @id @default(autoincrement())
  operationId          String              @unique
  operationDate        String
  typeOfOperation      String
  category             String
  description          String
  comment              String?
  payPurpose           String
  accountAmount        Float
  counterPartyAccount  String
  counterPartyInn      String
  counterPartyKpp      String
  counterPartyBic      String
  counterPartyBankName String
  counterPartyTitle    String
  expenseCategoryId    Int?
  expenseCategoryName  String?
  accountId            Int
