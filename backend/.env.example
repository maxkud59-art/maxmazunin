# Database
DATABASE_URL="postgresql://cabinet:cabinet_secret@localhost:5432/cabinet"

# Production (docker-compose.prod.yml)
# DB_NAME=cabinet
# DB_USER=cabinet
# DB_PASSWORD=replace-with-strong-password

# JWT
JWT_SECRET="replace-with-long-random-secret-min-32-chars"
JWT_EXPIRES_IN="7d"

# Server
PORT=3001
FRONTEND_URL="http://localhost:3000"

# First admin (for npm run admin:create)
ADMIN_EMAIL="admin@maxmazunin.ru"
ADMIN_PASSWORD="replace-with-strong-admin-password"

# Redis (optional — REDIS_ENABLED=true to activate)
REDIS_ENABLED=false
REDIS_URL="redis://:redis_secret@localhost:6379"

# ─── Мессенджер ───────────────────────────────────────────────────────────────
# true = тест-режим (матрица прав отключена, все пишут всем)
MESSENGER_TEST_MODE=true
# Email кому выдать роль GEN_DIRECTOR при seed (по умолчанию = ADMIN_EMAIL)
GENDIR_EMAIL=

# ─── VK Ads ───────────────────────────────────────────────────────────────────
# Платформа: "new" = ads.vk.com/api/v2  |  "old" = vk.com API (требует VK_ACCOUNT_ID)
VK_API_PLATFORM="new"
VK_ACCESS_TOKEN="replace-with-your-vk-ads-access-token"
# Нужен только для VK_API_PLATFORM=old
VK_ACCOUNT_ID=""
# Интервал сбора снимков (минуты, по умолчанию 5)
POLL_INTERVAL_MINUTES=5
