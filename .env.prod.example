# ─── PostgreSQL ───────────────────────────────────────────────────────────────
DB_NAME=cabinet
DB_USER=cabinet
DB_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD

# Используется backend-контейнером (hostname = имя сервиса в docker-compose)
DATABASE_URL=postgresql://cabinet:CHANGE_ME_STRONG_DB_PASSWORD@postgres:5432/cabinet

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_MIN_32_RANDOM_CHARACTERS
JWT_EXPIRES_IN=7d

# ─── NestJS ───────────────────────────────────────────────────────────────────
PORT=3001
FRONTEND_URL=https://maxmazunin.ru

# ─── Первый администратор (используется npm run admin:create / deploy.sh) ─────
ADMIN_EMAIL=admin@maxmazunin.ru
ADMIN_PASSWORD=CHANGE_ME_STRONG_ADMIN_PASSWORD

# ─── Let's Encrypt ────────────────────────────────────────────────────────────
LETSENCRYPT_EMAIL=admin@maxmazunin.ru

# ─── Nuxt (переопределяет docker-compose.prod.yml) ────────────────────────────
NUXT_PUBLIC_API_BASE=https://maxmazunin.ru

# ─── VK Ads (опционально) ─────────────────────────────────────────────────────
# Токен VK Ads API (ads.vk.com). Токены имеют срок жизни — при истечении обновить здесь
# и перезапустить backend: pm2 restart cabinet-backend
# ХРАНИТЬ ТОЛЬКО НА СЕРВЕРЕ, не коммитить в репозиторий!
VK_ACCESS_TOKEN=
VK_API_PLATFORM=new
POLL_INTERVAL_MINUTES=5

# ─── Book Layout: AI-зрение (опционально) ─────────────────────────────────────
# При отсутствии — авто-расстановка работает только по EXIF (без AI-анализа сцен)
VISION_API_KEY=

# ─── ИИ-ассистент: VK-сообщения сообщества ────────────────────────────────────
# Community access token с правами messages (получить на vk.com/editapp?act=tokens)
# ХРАНИТЬ ТОЛЬКО НА СЕРВЕРЕ, не коммитить в репозиторий!
VK_GROUP_TOKEN=
VK_GROUP_ID=
